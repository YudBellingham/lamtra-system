# ==================== AI SERVICE - Environment Configuration ====================
# Copy file này thành .env và điền thông tin của bạn

# ==================== SERVER CONFIGURATION ====================
PORT=5001
NODE_ENV=development

# ==================== GROQ API ====================
# Lấy API Key tại: https://console.groq.com/
# Model: llama-3.3-70b-versatile (hoặc mô hình khác)
GROQ_API_KEY=your_groq_api_key_here

# ==================== SUPABASE DATABASE ====================
# Kết nối database Supabase để truy vấn dữ liệu menu, khách hàng, đơn hàng
VITE_SUPABASE_URL=https://tpwgbutlqmubdnnnfhdp.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRwd2didXRscW11YmRubm5maGRwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMyMTgwMDAsImV4cCI6MjA4ODc5NDAwMH0.N11fA3pyYUpbtGPs0yvM9lwQecM6AJIwLEnGKNswfVI

# Hoặc nếu sử dụng biến tên khác:
# SUPABASE_URL=...
# SUPABASE_KEY=...

# ==================== CORS - Frontend URL ====================
# Để nhận request từ frontend
FRONTEND_URL=http://localhost:5173

# ==================== LOCAL DEVELOPMENT SETUP ====================
# Khi chạy "node server.js" trong thư mục ai-service:
# - Server sẽ chạy trên http://localhost:5001
# - Frontend sẽ gọi API tới /api/chat
# - Cần Groq API Key và Supabase credentials để hoạt động
#
# Verify Supabase kết nối:
#   - Kiểm tra log: "[Database: Supabase (Connected)]"
#   - Kiểm tra không có error về SUPABASE_URL hoặc SUPABASE_KEY

